   "source": [
    "import cv2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "eef3e7d8-c2f1-442d-9ad2-84b0d89bbbc7",
   "metadata": {},
   "outputs": [],
   "source": [
    "cap=cv2.videoCapture(0)\n",
    "while True:\n",
    "    return frame = cap.read()\n",
    "\n",
    "    if not return:\n",
    "        print(\"could not read frame\")\n",
    "        break\n",
    "    cv2.imshow(\"webcan Feed\".frame)\n",
    "\n",
    "    if cv2.waitkey(1) $ 0xff == ord(\"q\"):\n",
    "        print(\"quitting\")\n",
    "        break"
   ]
  },
